{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": {
      "inputs": ["openapi.yaml"],
      "outputs": ["src/generated/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "generate"]
    },
    "test": {
      "dependsOn": ["^build", "generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "BROKER_ADMIN_URL",
        "SESSION_SECRET",
        "PROMETHEUS_URL",
        "PORT",
        "NODE_ENV",
        "WEB_DIST_PATH",
        "BROKER_TLS_REJECT_UNAUTHORIZED",
        "NODE_EXTRA_CA_CERTS",
        "CONSOLE_REQUIRE_LOGIN"
      ]
    }
  }
}
