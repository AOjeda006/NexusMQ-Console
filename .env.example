# Variables de entorno de la consola (BFF). Cópialo a `.env` y ajústalo.
# Los secretos van SIEMPRE por entorno: nunca se hornean en la imagen ni se
# commitean. `.env` está en .gitignore.

# Secreto de sesión del BFF (firma la cookie httpOnly). Mínimo 32 caracteres.
# Genéralo, p. ej.: openssl rand -hex 32
SESSION_SECRET=

# TTL de una sesión de operador, en horas (por defecto 8). Vencida, el BFF la
# purga y exige volver a iniciar sesión.
# SESSION_TTL_HOURS=8

# Plano de operación admin del broker NexusMQ (URL interna del despliegue).
BROKER_ADMIN_URL=http://broker:8080

# Data source de historia (opcional). Sin él, la vista de Historia degrada limpio.
PROMETHEUS_URL=http://prometheus:9090

# Puerto en el que escucha la consola (por defecto 3000).
PORT=3000

# Opcional — TLS del broker:
# BROKER_TLS_REJECT_UNAUTHORIZED=true
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/broker-ca.pem
